{
  "version": "0.2.0",
  "configurations": [
      {
          "name": "STM32 Debugging (DAPLink)",
          "type": "cortex-debug",
          "request": "launch",
          "cwd": "${workspaceFolder}",
          "executable": "${workspaceFolder}/build/ActionBus.elf",
          "servertype": "openocd",
          "device": "STM32F407ZETx",
          "gdbPath": "/usr/bin/gdb-multiarch",
          "armToolchainPath": "/usr/bin",
          "configFiles": [
              "interface/cmsis-dap.cfg",
              "target/stm32f4x.cfg"
          ],
          "searchDir": [
              "/usr/share/openocd/scripts"
          ],
          "runToEntryPoint": "main"
      }
  ]
}